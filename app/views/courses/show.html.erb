<% content_for :title, @course.title %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
  <%# Flash Notice %>
  <% if notice.present? %>
    <div
      id="notice"
      class="
        mb-6 p-4 bg-green-50 border-l-4 border-green-400 text-green-700 font-medium
        rounded-md shadow-sm animate-fade-in-down
      "
    >
      <%= notice %>
    </div>
  <% end %>

  <%# Course Profile Card %>
  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden mb-8">
    <div class="px-6 py-8 sm:px-8 flex flex-col sm:flex-row items-start sm:items-center gap-6">
      <div
        class="
          h-16 w-16 rounded-full bg-blue-100 flex items-center justify-center text-blue-600
          text-2xl font-bold ring-4 ring-white shadow
        "
      >
        <%= @course.title[0] %>
      </div>
      <div class="flex-1">
        <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight"><%= @course.title %></h1>
        <p class="text-slate-500 mt-1"><%= @course.description %></p>
      </div>
      <div class="flex gap-2 flex-wrap">
        <%= link_to edit_course_path(@course), class: "inline-flex items-center px-4 py-2 bg-amber-50 hover:bg-amber-100 text-amber-700 text-sm font-bold rounded-xl transition-all", title: "Edit" do %>
          <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"
            /></svg>
          Edit
        <% end %>
        <%= link_to courses_path, class: "inline-flex items-center px-4 py-2 bg-slate-100 hover:bg-slate-200 text-slate-700 text-sm font-bold rounded-xl transition-all" do %>
          <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M10 19l-7-7m0 0l7-7m-7 7h18"
            /></svg>
          Back
        <% end %>
        <%= button_to @course, method: :delete, class: "inline-flex items-center px-4 py-2 bg-red-50 hover:bg-red-100 text-red-700 text-sm font-bold rounded-xl transition-all cursor-pointer", data: { turbo_confirm: "Delete this course?" } do %>
          <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"
            /></svg>
          Delete
        <% end %>
      </div>
    </div>
  </div>

  <%# Instructor Section %>
  <div class="mb-8">
    <div class="mb-4">
      <h2 class="text-xl font-extrabold text-slate-900 tracking-tight">Instructor</h2>
    </div>
    <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden px-6 py-5">
      <% if @course.teacher.present? %>
        <div class="flex items-center gap-4">
          <div
            class="
              h-10 w-10 rounded-full bg-blue-100 flex items-center justify-center text-blue-600
              text-sm font-bold ring-2 ring-white
            "
          >
            <%= @course.teacher.name[0] %>
          </div>
          <div>
            <%= link_to @course.teacher, class: "text-sm font-bold text-slate-900 hover:text-blue-600 transition-colors" do %>
              <%= @course.teacher.name %>
            <% end %>
            <div class="text-xs text-slate-400 line-clamp-1"><%= @course.teacher.bio %></div>
          </div>
        </div>
      <% else %>
        <span
          class="
            inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-bold
            bg-amber-50 text-amber-700 border border-amber-100 italic
          "
        >
          Unassigned
        </span>
      <% end %>
    </div>
  </div>

  <%# Enrolled Students %>
  <div class="mb-4">
    <h2 class="text-xl font-extrabold text-slate-900 tracking-tight">Enrolled Students</h2>
    <p class="text-slate-500 text-sm mt-1">Students currently registered in this course.</p>
  </div>

  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
    <table class="min-w-full divide-y divide-slate-200">
      <thead class="bg-slate-50/50">
        <tr>
          <th
            scope="col"
            class="
              px-6 py-4 text-left text-[10px] font-black text-slate-400 uppercase
              tracking-widest
            "
          >Student</th>
          <th
            scope="col"
            class="
              px-6 py-4 text-left text-[10px] font-black text-slate-400 uppercase
              tracking-widest
            "
          >Email</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100 bg-white">
        <% if @course.students.any? %>
          <% @course.students.order(:name).each do |student| %>
            <tr class="hover:bg-slate-50/50 transition-colors group">
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="flex items-center">
                  <div
                    class="
                      h-7 w-7 rounded-full bg-blue-100 flex items-center justify-center text-blue-600
                      text-[10px] font-bold ring-2 ring-white
                    "
                  >
                    <%= student.name[0] %>
                  </div>
                  <%= link_to student, class: "ml-2.5 text-sm font-bold text-slate-900 group-hover:text-blue-600 transition-colors" do %>
                    <%= student.name %>
                  <% end %>
                </div>
              </td>
              <td class="px-6 py-4">
                <div class="text-sm text-slate-500"><%= student.email %></div>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="2" class="px-6 py-12 text-center text-slate-500 italic">
              No students enrolled yet.
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
